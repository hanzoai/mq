{
  "name": "hanzoai/mq",
  "version": "1.0.1",
  "description": "Hanzo MQ queue client for PHP - Schedule jobs to be processed by Hanzo MQ workers",
  "keywords": [
    "queue",
    "valkey",
    "redis",
    "hanzo",
    "mq",
    "job",
    "scheduler",
    "background",
    "task",
    "worker"
  ],
  "type": "library",
  "license": "MIT",
  "homepage": "https://hanzo.ai/",
  "support": {
    "docs": "https://docs.hanzo.ai/",
    "issues": "https://github.com/hanzoai/mq/issues",
    "source": "https://github.com/hanzoai/mq"
  },
  "authors": [
    {
      "name": "Hanzo AI",
      "email": "dev@hanzo.ai"
    }
  ],
  "require": {
    "php": "^8.1",
    "predis/predis": "^2.0",
    "ramsey/uuid": "^4.7",
    "rybakit/msgpack": "^0.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "BullMQ\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BullMQ\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse src --level=6",
    "cs": "phpcs src --standard=PSR12",
    "cs-fix": "phpcbf src --standard=PSR12"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
